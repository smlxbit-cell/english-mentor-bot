# -------------------------------------------------------------------
# English Mentor Bot — environment variables.
# Copy to .env and fill in. .env is gitignored.
# -------------------------------------------------------------------

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# If VPS cannot reach api.telegram.org (curl times out), set a proxy:
# TELEGRAM_PROXY=socks5://127.0.0.1:1080
TELEGRAM_PAYMENT_PROVIDER_TOKEN=

# Subscription (single plan): 390 RUB / 30 days, no auto-renewal.
SUBSCRIPTION_PRICE_RUB=390
SUBSCRIPTION_DAYS=30
TRIAL_LESSONS_LIMIT=2
# 'mock' = instant activation for dev; 'live' = real YooKassa after approval.
PAYMENT_MODE=mock

# YooKassa (fill after the store is approved)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# AI provider — economical answer checking, hints, AI dialogue.
# 'openai' | 'openai_compatible' (any OpenAI-style gateway) | 'mock' (offline).
# Auto-selects mock if OPENAI_API_KEY is empty.
AI_PROVIDER=openai_compatible
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional tiered models (fall back to OPENAI_MODEL if unset).
OPENAI_CHEAP_MODEL=
OPENAI_ADVANCED_MODEL=
# Base URL of the OpenAI-compatible endpoint (e.g. a proxy/gateway).
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MAX_OUTPUT_TOKENS=400
AI_HISTORY_MESSAGES=8
AI_TIMEOUT_SECONDS=30
# Internal guardrail (optional): max AI calls per user per day.
AI_DAILY_CALL_LIMIT_PER_USER=40

# Text-to-speech (voicing English words/phrases so learners can listen).
# 'edge' = free Microsoft neural voices (no key); 'openai' = uses OPENAI_* above.
TTS_ENABLED=true
TTS_PROVIDER=edge
TTS_VOICE=en-US-AriaNeural
# Used only when TTS_PROVIDER=openai
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# Speech-to-text for voice answers — Yandex SpeechKit.
# 'yandex' or 'mock'. Auto-selects mock if YANDEX_SPEECHKIT_API_KEY is empty.
STT_PROVIDER=
YANDEX_SPEECHKIT_API_KEY=
YANDEX_FOLDER_ID=

# Production server (Yandex Cloud / VPS)
DEBUG=false
DJANGO_SECRET_KEY=generate-a-long-random-string-here
ALLOWED_HOSTS=127.0.0.1,localhost
TIME_ZONE=Europe/Moscow
